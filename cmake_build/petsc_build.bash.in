#!/bin/bash

CMAKE_SOURCE_DIR=@CMAKE_SOURCE_DIR@
petsc_dir=${CMAKE_SOURCE_DIR}/petsc

cd ${petsc_dir} && ./configure --with-debugging=0 --with-fc=0 --with-cxx=0 --download-sundials2 --download-mpich --COPTFLAGS="-O3" --CXXOPTFLAGS="-O3" -CC=${CC}

arch=arch-$(uname -s | awk '{print tolower($0)}')-c-opt

cd ${petsc_dir} && make PETSC_DIR=${petsc_dir} PETSC_ARCH=${arch} all
cd ${petsc_dir} && make PETSC_DIR=${petsc_dir} PETSC_ARCH=${arch} check
